<<<<<<< HEAD
      // Read: Owner can read self. Admin and Boku_Access can read anyone in the client.
      allow get: if isOwner(portalUserId) || isClientAdmin(clientId) || isBokuAccess(clientId);
      // List: Admin and Boku_Access can list all users in the client.
      allow list: if isClientAdmin(clientId) || isBokuAccess(clientId);

      // Create: Admin can create any role. Boku_Access can only create Client_Access. Data must be valid.
      allow create: if (isClientAdmin(clientId) || (isBokuAccess(clientId) && request.resource.data.role == 'Client_Access'))
                    && isPortalUserDataValidOnCreate(clientId, portalUserId);

      // Update: Owner can update self. Admin can update anyone. Boku_Access can update Client_Access. Data and roles must be valid.
