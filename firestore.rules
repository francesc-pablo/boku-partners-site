/**
 * This ruleset implements a secure, multi-tenant model for a client portal.
 *
 * Core Philosophy:
 * The security model is built on strict data partitioning by a top-level client ID (`clientId`).
 * All data for a specific client is nested under `/clients/{clientId}`, ensuring that users
 * from one client can never access data from another. Within each client's data partition,
 * a Role-Based Access Control (RBAC) system is used, primarily distinguishing between
 * 'Admin' and standard users.
 *
 * Data Structure:
 * - /clients/{clientId}: The root document for a single client tenant.
 * - /clients/{clientId}/portalUsers/{portalUserId}: A subcollection containing user profiles for that client.
 * - /clients/{clientId}/quickBooksIntegration/{quickBooksIntegrationId}: A subcollection for sensitive integration data.
 *
 * Key Security Decisions:
 * - Strict Tenant Isolation: All rules verify that the requesting user belongs to the `clientId`
 *   specified in the document path, preventing any cross-tenant data access.
 * - Admin-Based Management: Users with the 'Admin' role within a client can manage other users
 *   and sensitive integration settings for that client only.
 * - User Self-Service: Users can view and update their own profile information but cannot
 *   view other users' profiles unless they are an admin.
 * - Deny by Default: Listing all clients is disallowed, and creation/deletion of top-level
 *   client documents is restricted, assuming these are backend-controlled operations.
 * - Denormalization for Authorization: User roles and client IDs are stored directly on
 *   `portalUser` documents. This allows security rules to determine a user's permissions
 *   for a given client with a single `get` operation on their own user document, which is
 *   efficient and secure.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //----------------------------------------------------------------//
    //                        Helper Functions                        //
    //----------------------------------------------------------------//

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the requesting user's UID matches the provided userId.
     * Used for checking document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * A reusable function to retrieve the requesting user's own PortalUser document data.
     * This is the source of truth for their role and clientId.
     */
    function getRequestingUserData(clientId) {
      return get(/databases/$(database)/documents/clients/$(clientId)/portalUsers/$(request.auth.uid)).data;
    }

    /**
     * Returns true if the requesting user is a member of the specified client organization.
     * It checks for the existence of a mapping document that links the user's UID to a clientId.
     */
    function isClientMember(clientId) {
      return isSignedIn() 
        && exists(/databases/$(database)/documents/user_to_client_map/$(request.auth.uid))
        && get(/databases/$(database)/documents/user_to_client_map/$(request.auth.uid)).data.clientId == clientId;
    }

    /**
     * Returns true if the requesting user is an 'Admin' for the specified client.
     * This implicitly checks for membership as the 'get' will fail if the user document doesn't exist.
     */
    function isClientAdmin(clientId) {
      return isClientMember(clientId) && getRequestingUserData(clientId).role == 'Admin';
    }
    
    /**
     * Validates that the `clientId` and `id` fields in a new portalUser document
     * match the document's path, ensuring relational integrity.
     */
    function isPortalUserDataValidOnCreate(clientId, portalUserId) {
      let incomingData = request.resource.data;
      return incomingData.clientId == clientId && incomingData.id == portalUserId
          && (isClientAdmin(clientId) || isOwner(portalUserId)); // An admin or the user themselves can create their own doc during signup
    }

    /**
     * Ensures critical relational IDs on a portalUser document cannot be changed after creation.
     * Allow role changes only by an Admin.
     */
    function arePortalUserFieldsValidOnUpdate(clientId) {
      let incomingData = request.resource.data;
      let existingData = resource.data;
      let roleIsChanging = incomingData.role != existingData.role;

      return incomingData.clientId == existingData.clientId 
          && incomingData.id == existingData.id
          && (!roleIsChanging || isClientAdmin(clientId)); // Only admins can change roles
    }


    //----------------------------------------------------------------//
    //                         Collection Rules                       //
    //----------------------------------------------------------------//

    /**
     * @description Public mapping from a user's UID to their client ID.
     * Any authenticated user needs to be able to read their own mapping to find their client.
     * A user can create their own mapping during signup.
     */
    match /user_to_client_map/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.clientId != null;
      allow list, update, delete: if false;
    }

    /**
     * @description Rules for the top-level client tenant documents.
     * A user can create a client as part of the signup flow. 
     * Only members of that client can read the client document.
     */
    match /clients/{clientId} {
      allow get: if isClientMember(clientId);
      allow list: if false; // Deny listing all clients for security
      allow create: if isSignedIn();
      allow update: if isClientAdmin(clientId);
      allow delete: if false;
    }

    /**
     * @description Rules for portal user accounts, which are nested under a specific client.
     */
    match /clients/{clientId}/portalUsers/{portalUserId} {
      allow get: if isOwner(portalUserId) || isClientAdmin(clientId);
      allow list: if isClientAdmin(clientId);

      // User is created by Admin or during their own signup process
      allow create: if isSignedIn() && isPortalUserDataValidOnCreate(clientId, portalUserId);

      // User can update their own profile, Admin can update any profile in their client.
      allow update: if (isOwner(portalUserId) || isClientAdmin(clientId)) && arePortalUserFieldsValidOnUpdate(clientId);
      
      allow delete: if isClientAdmin(clientId);
    }
    
    // Deny all client-side reads and writes to the oauth_states collection.
    // Only our server-side code should touch this.
    match /oauth_states/{stateId} {
      allow read, write: if false;
    }

    /**
     * @description Rules for the highly sensitive QuickBooks integration data.
     * Client-side code is allowed to check for the *existence* of an integration
     * document via a `list` query, but it is NOT allowed to `get` (read) the
     * actual document containing sensitive tokens. All write operations are
     * also denied from the client, as they are handled by secure server-side actions.
     */
    match /clients/{clientId}/quickBooksIntegration/{quickBooksIntegrationId} {
      allow get: if false;
      allow list: if isClientMember(clientId);
      allow write: if false;
    }
  }
}
