/**
 * This ruleset implements a secure, multi-tenant model for a client portal.
 *
 * Core Philosophy:
 * The security model is built on strict data partitioning by a top-level client ID (`clientId`).
 * All data for a specific client is nested under `/clients/{clientId}`, ensuring that users
 * from one client can never access data from another. Within each client's data partition,
 * a Role-Based Access Control (RBAC) system is used, distinguishing between 'Admin', 'Boku_Access',
 * and 'StandardUser' roles.
 *
 * Data Structure:
 * - /clients/{clientId}: The root document for a single client tenant.
 * - /clients/{clientId}/portalUsers/{portalUserId}: A subcollection containing user profiles for that client.
 * - /clients/{clientId}/quickBooksIntegration/{quickBooksIntegrationId}: A subcollection for sensitive integration data.
 *
 * Key Security Decisions:
 * - Strict Tenant Isolation: All rules verify that the requesting user belongs to the `clientId`
 *   specified in the document path, preventing any cross-tenant data access.
 * - Role-Based Management: 'Admin' users can manage any user. 'Boku_Access' users can manage
 *   'StandardUser' accounts, providing a middle tier of administrative capability.
 * - User Self-Service: Users can view and update their own profile information.
 * - Deny by Default: Listing all clients is disallowed, and creation/deletion of top-level
 *   client documents is restricted, assuming these are backend-controlled operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //----------------------------------------------------------------//
    //                        Helper Functions                        //
    //----------------------------------------------------------------//

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRequestingUserRole(clientId) {
      let userDocPath = /databases/$(database)/documents/clients/$(clientId)/portalUsers/$(request.auth.uid);
      // The `get` is allowed by the `get` rule, which lets a user read their own document.
      let userDoc = get(userDocPath);
      if (exists(userDocPath)) {
        return userDoc.data.role;
      }
      return null;
    }
    
    function isClientAdmin(clientId) {
      return getRequestingUserRole(clientId) == 'Admin';
    }

    function isBokuAccess(clientId) {
      return getRequestingUserRole(clientId) == 'Boku_Access';
    }

    function isClientMember(clientId) {
      return isSignedIn() 
        && exists(/databases/$(database)/documents/clients/$(clientId)/portalUsers/$(request.auth.uid));
    }
    
    function isPortalUserDataValidOnCreate(clientId, portalUserId) {
      let incomingData = request.resource.data;
      return incomingData.clientId == clientId && incomingData.id == portalUserId;
    }

    function arePortalUserFieldsValidOnUpdate(clientId) {
      let incomingData = request.resource.data;
      let existingData = resource.data;
      let roleIsChanging = incomingData.role != existingData.role;

      return incomingData.clientId == existingData.clientId 
          && incomingData.id == existingData.id
          && (!roleIsChanging || isClientAdmin(clientId)); // Only admins can change roles
    }


    //----------------------------------------------------------------//
    //                         Collection Rules                       //
    //----------------------------------------------------------------//

    match /user_to_client_map/{userId} {
      allow get: if isOwner(userId);
      // Admin or Boku_Access users can create the mapping record for a new user in their client.
      allow create: if isClientAdmin(request.resource.data.clientId) || isBokuAccess(request.resource.data.clientId);
      allow delete: if isClientAdmin(resource.data.clientId) || isBokuAccess(resource.data.clientId);
      allow list, update: if false;
    }

    match /clients/{clientId} {
      allow get: if isClientMember(clientId);
      allow list: if false;
      allow create: if false;
      allow update: if isClientAdmin(clientId);
      allow delete: if false;
    }

    match /clients/{clientId}/portalUsers/{portalUserId} {
      // Read: Owner can read self. Admin and Boku_Access can read anyone in the client.
      allow get: if isOwner(portalUserId) || isClientAdmin(clientId) || isBokuAccess(clientId);
      // List: Admin and Boku_Access can list all users in the client.
      allow list: if isClientAdmin(clientId) || isBokuAccess(clientId);

      // Create: Admin can create any role. Boku_Access can only create StandardUser. Data must be valid.
      allow create: if (isClientAdmin(clientId) || (isBokuAccess(clientId) && request.resource.data.role == 'StandardUser'))
                    && isPortalUserDataValidOnCreate(clientId, portalUserId);

      // Update: Owner can update self. Admin can update anyone. Boku_Access can update StandardUser. Data and roles must be valid.
      allow update: if (isOwner(portalUserId) || isClientAdmin(clientId) || (isBokuAccess(clientId) && resource.data.role == 'StandardUser')) 
                    && arePortalUserFieldsValidOnUpdate(clientId);
      
      // Delete: Admin can delete anyone (but not themselves). Boku_Access can delete StandardUser.
      allow delete: if (isClientAdmin(clientId) && !isOwner(portalUserId)) || 
                     (isBokuAccess(clientId) && resource.data.role == 'StandardUser');
    }
    
    match /oauth_states/{stateId} {
      allow read, write: if true;
    }

    match /clients/{clientId}/quickBooksIntegration/{quickBooksIntegrationId} {
      allow get: if true;
      allow list: if true;
      allow create: if true;
      allow update, delete: if false;
    }
  }
}
