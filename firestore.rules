/**
 * This ruleset implements a secure, multi-tenant model for a client portal with tiered role-based access.
 *
 * Core Philosophy:
 * Data is strictly partitioned by `clientId`. The RBAC system operates within each client partition.
 *
 * Roles:
 * - Admin: Full control over all users and settings within their client.
 * - Boku_Access: Can manage (add, edit, delete) 'Client_Access' users. Cannot edit Admins or other Boku_Access users.
 * - Client_Access: Standard user, can only view and edit their own profile.
 *
 * Key Security Decisions:
 * - Strict Tenant Isolation: All rules verify that a user belongs to the `clientId` in the path.
 * - Hierarchical Permissions: Access is layered. Admins have the highest permissions, Boku_Access has a subset, and Client_Access has the most limited.
 * - Self-Service with Restrictions: Users can edit their own profiles but are blocked from changing their own role or client affiliation.
 * - Admin Safeguards: Admins cannot delete their own accounts to prevent accidental lockouts.
 * - Deny by Default: Listing all clients is disallowed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //----------------------------------------------------------------//
    //                        Helper Functions                        //
    //----------------------------------------------------------------//

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Retrieves the role of the currently authenticated user for a specific client.
     * This is a central function for our RBAC. It performs a single `get` to the
     * user's own profile to determine their permissions within the client context.
     */
    function getRequestingUserRole(clientId) {
      let userDoc = get(/databases/$(database)/documents/clients/$(clientId)/portalUsers/$(request.auth.uid));
      return userDoc.data.role;
    }

    function isAdmin(clientId) {
      return getRequestingUserRole(clientId) == 'Admin';
    }

    function isBokuAccess(clientId) {
      return getRequestingUserRole(clientId) == 'Boku_Access';
    }

    function isClientMember(clientId) {
      return isSignedIn() && exists(/databases/$(database)/documents/clients/$(clientId)/portalUsers/$(request.auth.uid));
    }
    
    /**
     * Validates data for a new portal user.
     * - An Admin can create a user with any role.
     * - A Boku_Access user can only create 'Client_Access' users.
     */
    function isPortalUserDataValidOnCreate(clientId, portalUserId) {
      let incomingData = request.resource.data;
      let requesterRole = getRequestingUserRole(clientId);
      
      let isDataSane = incomingData.clientId == clientId && incomingData.id == portalUserId;
      let isAdminCreating = requesterRole == 'Admin';
      let isBokuAccessCreating = requesterRole == 'Boku_Access' && incomingData.role == 'Client_Access';

      return isDataSane && (isAdminCreating || isBokuAccessCreating);
    }
    
    /**
     * Validates data on a portal user update.
     * - Any user can edit their own non-critical profile info (cannot change role/clientId).
     * - An Admin can edit any user and change their role.
     * - A Boku_Access user can only edit 'Client_Access' users and cannot change their role.
     */
    function arePortalUserFieldsValidOnUpdate(clientId, portalUserId) {
      let incomingData = request.resource.data;
      let existingData = resource.data;
      let requesterRole = getRequestingUserRole(clientId);

      let isSelfEdit = isOwner(portalUserId) &&
          incomingData.id == existingData.id &&
          incomingData.clientId == existingData.clientId &&
          incomingData.role == existingData.role; // Cannot change own role

      let isAdminEdit = isAdmin(clientId) &&
          incomingData.id == existingData.id &&
          incomingData.clientId == existingData.clientId; // Admin can change roles

      let isBokuAccessEdit = isBokuAccess(clientId) &&
          existingData.role == 'Client_Access' && // Can only edit Client_Access users
          incomingData.id == existingData.id &&
          incomingData.clientId == existingData.clientId &&
          incomingData.role == 'Client_Access'; // Cannot change their role

      return isSelfEdit || isAdminEdit || isBokuAccessEdit;
    }


    //----------------------------------------------------------------//
    //                         Collection Rules                       //
    //----------------------------------------------------------------//

    match /user_to_client_map/{userId} {
      allow get: if isOwner(userId);
      // An admin or boku_access must create the mapping when adding a new user.
      allow create: if isAdmin(request.resource.data.clientId) || isBokuAccess(request.resource.data.clientId);
      allow delete: if isAdmin(resource.data.clientId) || isBokuAccess(resource.data.clientId);
      allow list, update: if false;
    }

    match /clients/{clientId} {
      allow get: if isClientMember(clientId);
      allow list: if false;
      allow create: if false;
      allow update: if isAdmin(clientId) || isBokuAccess(clientId);
      allow delete: if false;
    }

    match /clients/{clientId}/portalUsers/{portalUserId} {
      // Admins and Boku_Access can get any user doc, others can only get their own.
      allow get: if isOwner(portalUserId) || isAdmin(clientId) || isBokuAccess(clientId);
      // Admins and Boku_Access can list all users in the client.
      allow list: if isAdmin(clientId) || isBokuAccess(clientId);
      // Creation rules are handled by the helper function.
      allow create: if isPortalUserDataValidOnCreate(clientId, portalUserId);
      // Update rules are handled by the helper function.
      allow update: if arePortalUserFieldsValidOnUpdate(clientId, portalUserId);
      // Admins can delete anyone but themselves. Boku_Access can only delete Client_Access users.
      allow delete: if (isAdmin(clientId) && !isOwner(portalUserId)) || 
                     (isBokuAccess(clientId) && resource.data.role == 'Client_Access' && !isOwner(portalUserId));
    }
    
    match /oauth_states/{stateId} {
      allow read, write: if true;
    }

    match /clients/{clientId}/quickBooksIntegration/{quickBooksIntegrationId} {
      allow get: if isClientMember(clientId);
      allow list: if isClientMember(clientId);
      allow create: if isAdmin(clientId) || isBokuAccess(clientId);
      allow update, delete: if false;
    }
  }
}
